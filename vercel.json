{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "pitchdeck.kengkad.com"
        }
      ],
      "destination": "/pitchdeck"
    },
    {
      "source": "/",
      "destination": "/landing"
    }
  ]
}
